# ── Django ────────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=warehouse_dms.settings

# ── Database ──────────────────────────────────────────────────────────────────
# Full DSN parsed by dj-database-url.
# For Docker Compose use the service name "db".
DATABASE_URL=postgresql://wdms_user:wdms_pass@db:5432/warehouse_dms

# Alternatively set these and the Compose file will pick them up for the db service:
POSTGRES_DB=warehouse_dms
POSTGRES_USER=wdms_user
POSTGRES_PASSWORD=wdms_pass
POSTGRES_HOST_PORT=5433

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=6380

# ── Docker host ports ─────────────────────────────────────────────────────────
WEB_HOST_PORT=8001

# ── JWT ───────────────────────────────────────────────────────────────────────
# SIGNING_KEY must be the same secret used to sign and verify tokens.
SIGNING_KEY=change-me-to-another-long-random-string
VERIFYING_KEY=

# Access token lifetime in seconds (default 86400 = 24 hours)
ACCESS_TOKEN_LIFETIME_SECONDS=86400

# ── Admin seed credentials ────────────────────────────────────────────────────
DEFAULT_SUPER_USERNAME=admin
DEFAULT_SUPER_EMAIL=admin@warehousedms.local
DEFAULT_SUPER_PASS=Admin@Wdms2026!

# Password assigned to users created via Google OAuth
DEFAULT_USER_PASSWORD=ChangeMe@1234!

# ── Login rate limiting ───────────────────────────────────────────────────────
MAX_ATTEMPTS_FAILURE=5
MAX_TIME_BLOCKED=300

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=no-reply@warehousedms.local

# ── Google OAuth (Phase 1 optional) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Phase 4 — Google Cloud AI services ───────────────────────────────────────
# Path to the service-account JSON (used by both Vision and Vertex AI).
# Roles required on the service account:
#   - roles/aiplatform.user      (Vertex AI Gemini + embeddings)
#   - roles/cloudvision.user     (Vision API OCR)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Override the model names if needed.
GEMINI_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-embedding-004

# Set to "true" to disable Google Cloud calls and use deterministic mocks.
# Mocks produce 768-dim normalised embeddings so semantic search still works.
USE_MOCK_AI_SERVICES=false
